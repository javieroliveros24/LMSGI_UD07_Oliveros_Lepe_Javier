<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_invoice_ubl_willmantech">
            <t t-set="doc" t-value="o.with_context(lang=lang)"/>
            
            <Invoice xmlns="urn:oasis:names:specification:ubl:schema:xsd:Invoice-2"
                     xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
                     xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicNameComponents-2">
                
                <cbc:CustomizationID>urn:cen.eu:en16931:2017#compliant#urn:fdc:peppol.eu:poacc:trns:invoice:3</cbc:CustomizationID>
                <cbc:ProfileID>urn:fdc:peppol.eu:poacc:bis:invoice:3</cbc:ProfileID>
                
                <cbc:ID><t t-out="doc.name"/></cbc:ID>
                <cbc:IssueDate><t t-out="doc.date"/></cbc:IssueDate>
                <cbc:InvoiceTypeCode>380</cbc:InvoiceTypeCode>
                <cbc:DocumentCurrencyCode><t t-out="doc.currency_id.name"/></cbc:DocumentCurrencyCode>
                
                <cac:AccountingSupplierParty>
                    <cac:Party>
                        <cac:PartyIdentification>
                            <cbc:ID schemeID="0088">8412345678901</cbc:ID>
                        </cac:PartyIdentification>
                        <cac:PartyName>
                            <cbc:Name>WillmanTech S.L.</cbc:Name>
                        </cac:PartyName>
                        <cac:PostalAddress>
                            <cbc:StreetName>Calle Isabela - Viapol</cbc:StreetName>
                            <cbc:CityName>Sevilla</cbc:CityName>
                            <cbc:PostalZone>41013</cbc:PostalZone>
                            <cac:Country>
                                <cbc:IdentificationCode>ES</cbc:IdentificationCode>
                            </cac:Country>
                        </cac:PostalAddress>
                        <cac:PartyTaxScheme>
                            <cbc:CompanyID>B12345678</cbc:CompanyID>
                            <cac:TaxScheme>
                                <cbc:ID>VAT</cbc:ID>
                            </cac:TaxScheme>
                        </cac:PartyTaxScheme>
                    </cac:Party>
                </cac:AccountingSupplierParty>
                
                <cac:AccountingCustomerParty>
                    <cac:Party>
                        <cac:PartyName>
                            <cbc:Name><t t-out="doc.partner_id.name"/></cbc:Name>
                        </cac:PartyName>
                        <cac:PostalAddress>
                            <cbc:StreetName><t t-out="doc.partner_id.street"/></cbc:StreetName>
                            <cbc:CityName><t t-out="doc.partner_id.city"/></cbc:CityName>
                            <cbc:PostalZone><t t-out="doc.partner_id.zip"/></cbc:PostalZone>
                            <cac:Country>
                                <cbc:IdentificationCode><t t-out="doc.partner_id.country_id.code"/></cbc:IdentificationCode>
                            </cac:Country>
                        </cac:PostalAddress>
                        <cac:PartyTaxScheme>
                            <cbc:CompanyID><t t-out="doc.partner_id.vat"/></cbc:CompanyID>
                            <cac:TaxScheme>
                                <cbc:ID>VAT</cbc:ID>
                            </cac:TaxScheme>
                        </cac:PartyTaxScheme>
                    </cac:Party>
                </cac:AccountingCustomerParty>
                
                <cac:LegalMonetaryTotal>
                    <cbc:LineExtensionAmount t-att-currencyID="doc.currency_id.name"><t t-out="doc.amount_untaxed"/></cbc:LineExtensionAmount>
                    <cbc:TaxExclusiveAmount t-att-currencyID="doc.currency_id.name"><t t-out="doc.amount_untaxed"/></cbc:TaxExclusiveAmount>
                    <cbc:TaxInclusiveAmount t-att-currencyID="doc.currency_id.name"><t t-out="doc.amount_total"/></cbc:TaxInclusiveAmount>
                    <cbc:PayableAmount t-att-currencyID="doc.currency_id.name"><t t-out="doc.amount_total"/></cbc:PayableAmount>
                </cac:LegalMonetaryTotal>
                
                <t t-foreach="doc.invoice_line_ids" t-as="line">
                    <t t-if="line.display_type == 'product'">
                        <cac:InvoiceLine>
                            <cbc:ID><t t-out="line_index + 1"/></cbc:ID>
                            <cbc:InvoicedQuantity unitCode="EA"><t t-out="line.quantity"/></cbc:InvoicedQuantity>
                            <cbc:LineExtensionAmount t-att-currencyID="doc.currency_id.name"><t t-out="line.price_subtotal"/></cbc:LineExtensionAmount>
                            <cac:Item>
                                <cbc:Name><t t-out="line.name"/></cbc:Name>
                                <cac:ClassifiedTaxCategory>
                                    <cbc:ID>S</cbc:ID>
                                    <cbc:Percent>21</cbc:Percent>
                                    <cac:TaxScheme>
                                        <cbc:ID>VAT</cbc:ID>
                                    </cac:TaxScheme>
                                </cac:ClassifiedTaxCategory>
                            </cac:Item>
                            <cac:Price>
                                <cbc:PriceAmount t-att-currencyID="doc.currency_id.name"><t t-out="line.price_unit"/></cbc:PriceAmount>
                            </cac:Price>
                        </cac:InvoiceLine>
                    </t>
                </t>
            </Invoice>
        </template>
    </data>
</odoo>